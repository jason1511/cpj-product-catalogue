{
  "name": "cpj-product-catalogue",
  "private": true,
  "version": "0.0.0",
  "type": "module",
 "scripts": {
  "dev": "vite",
  "build": "vite build",
  "preview": "vite preview",
  "check": "npm run build",
  "cf:dev": "npm run build && wrangler pages dev dist --d1 DB=876766b2-1023-4b79-9de4-85f924500324 --r2 PRODUCT_IMAGES=cpj-product-images",
  "cf:deploy": "npm run build && wrangler pages deploy dist",
  "db:seed:generate": "node scripts/generate-seed-products.js",
  "db:seed:local": "wrangler d1 execute cpj_catalogue_db --local --file=./migrations/0003_seed_products.sql",
  "db:seed:remote": "wrangler d1 execute cpj_catalogue_db --remote --file=./migrations/0003_seed_products.sql"
},
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "motion": "^12.39.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "wrangler": "^4.98.0"
  }
}
